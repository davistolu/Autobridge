{
  "name": "wirebridge/sdk-laravel",
  "description": "WireBridge SDK for Laravel — automatically wire your Laravel API to any frontend via the WireBridge runtime framework",
  "type": "library",
  "license": "MIT",
  "version": "0.1.0",
  "require": {
    "php": ">=8.1",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "laravel/framework": "^10.0|^11.0",
    "orchestra/testbench": "^8.0|^9.0"
  },
  "autoload": {
    "psr-4": {
      "WireBridge\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "WireBridge\\WireBridgeServiceProvider"
      ],
      "aliases": {
        "Bridge": "WireBridge\\Facades\\Bridge"
      }
    }
  },
  "minimum-stability": "stable"
}
